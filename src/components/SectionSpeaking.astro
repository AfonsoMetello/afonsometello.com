---
const talks = [
  {
    number: "01",
    type: "CONFERENCE TALK",
    title: "What a Samba Drum Taught Me About ML",
    description:
      "Selected for ONE: a live talk on mobile ML, repique and real-time response.",
    venue: "ONE26 · AMSTERDAM · 2026",
  },
  {
    number: "02",
    type: "CONFERENCE TALK",
    title: "EDA in Action: From Concepts to Rockets with OutSystems Events",
    description:
      "A live demo on event-driven architecture, with rockets included.",
    venue: "OUTSYSTEMS CONFERENCE",
  },
  {
    number: "03",
    type: "MEETUPS",
    title: "Wonderbool Meetups",
    description:
      "Smaller sessions, sharper topics, real community.",
    venue: "LISBON · PORTO · THE HAGUE · TERCEIRA",
  },
];

const offsets = ["", "ml-4 md:ml-12", "ml-8 md:ml-24"];
---

<section id="speaking" class="py-32 px-8 bg-surface">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-20">
    <div class="md:w-1/3">
      <h2 class="font-black text-6xl md:text-8xl uppercase tracking-tighter sticky top-32">SPEAKING</h2>
    </div>
    <div class="md:w-2/3 space-y-12">
      {talks.map((talk, i) => (
        <div class:list={["group border-b border-outline-variant/30 pb-12", offsets[i]]}>
          <h3 class:list={[
            "font-black uppercase tracking-tighter group-hover:translate-x-4 transition-none cursor-default",
            i === 0 ? "text-5xl md:text-[4.5rem]" : i === 1 ? "text-4xl md:text-[3rem]" : "text-3xl md:text-[2.75rem] font-extrabold",
          ]}>
            {talk.title}
          </h3>
          <p class="text-secondary font-medium mt-4 max-w-md opacity-65">{talk.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
