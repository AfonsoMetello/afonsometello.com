---
const badges = [
  { icon: "military_tech", label: "OutSystems Champion", description: "Recognized community leader. Mentoring developers and growing the ecosystem across Portugal and the Netherlands." },
  { icon: "school", label: "Certified Trainer", description: "Official OutSystems trainer. Running boot camps and preparing teams for certification." },
  { icon: "groups", label: "Wonderbool Meetup Organizer", description: "Founded and run indie OutSystems community meetups in 4 cities since 2019. By the community, for the community." },
];
---

<section id="community" class="py-32 px-8 bg-surface-container-lowest">
  <div class="max-w-7xl mx-auto">
    <h2 class="font-black text-6xl md:text-8xl uppercase tracking-tighter mb-20 text-outline">COMMUNITY</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {badges.map((badge, i) => (
        <div
          class:list={[
            "p-8 flex flex-col justify-between aspect-square group hover:bg-primary transition-none",
            i % 2 === 0 ? "bg-surface-container-highest" : "bg-surface-container-high",
            i % 2 !== 0 ? "lg:mt-12" : "",
          ]}
        >
          <span class="material-symbols-outlined text-5xl group-hover:text-on-primary">{badge.icon}</span>
          <div>
            <p class="font-black text-2xl uppercase tracking-tighter group-hover:text-on-primary">{badge.label}</p>
            <p class="text-secondary font-semibold uppercase text-sm mt-3 group-hover:text-on-primary">{badge.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
