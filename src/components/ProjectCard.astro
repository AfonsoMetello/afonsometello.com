---
interface Props {
  title: string;
  description: string;
  status: string;
  category: string;
  slug: string;
  index: number;
  total: number;
  image?: string;
}

const { title, description, status, category, slug, index, total } = Astro.props;
const counter = `${String(index).padStart(2, "0")} / ${String(total).padStart(2, "0")}`;
---

<a
  href={`/projects/${slug}`}
  class="project-card group bg-surface-container-high flex flex-col min-h-[400px]"
>
  <div class="h-[160px] bg-surface-container border-b border-outline-variant/10 flex items-center justify-center overflow-hidden">
    {Astro.props.image ? (
      <img src={Astro.props.image} alt={title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-[filter] duration-300" />
    ) : (
      <span class="material-symbols-outlined text-5xl opacity-15">terminal</span>
    )}
  </div>
  <div class="p-8 md:p-12 flex flex-col justify-between flex-1">
    <div>
      <div class="flex flex-wrap gap-3 mb-3">
        <span class="tag border-2 border-white px-3 py-1 text-xs font-black uppercase tracking-widest">{status}</span>
        <span class="tag border-2 border-white px-3 py-1 text-xs font-black uppercase tracking-widest">{category}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-none mb-6">
        {title}
      </h2>
      <p class="card-description text-secondary font-semibold text-lg uppercase leading-snug">
        {description}
      </p>
    </div>
    <div class="mt-12 flex justify-between items-end">
      <span class="material-symbols-outlined text-7xl">arrow_outward</span>
      <span class="card-counter text-xs font-black opacity-10">{counter}</span>
    </div>
  </div>
</a>
