---
import BlogPostRow from "./BlogPostRow.astro";

interface Props {
  posts: Array<{
    id: string;
    data: {
      title: string;
      date: Date;
      category: string;
    };
  }>;
}

const { posts } = Astro.props;
---

<section class="py-32 px-8 bg-surface">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-16">
      <h2 class="font-black text-6xl md:text-8xl uppercase tracking-tighter">BLOG</h2>
      <a
        href="/blog"
        class="font-black text-sm uppercase tracking-widest text-secondary hover:text-white transition-none"
      >
        VIEW ALL <span class="material-symbols-outlined align-middle text-sm">arrow_forward</span>
      </a>
    </div>
    <div class="flex flex-col">
      {posts.map((post) => (
        <BlogPostRow title={post.data.title} date={post.data.date} category={post.data.category} slug={post.id} />
      ))}
    </div>
    {posts.length === 0 && (
      <p class="text-secondary font-bold uppercase tracking-widest text-center py-20">COMING SOON</p>
    )}
  </div>
</section>
