---
import ProjectCard from "./ProjectCard.astro";

interface Props {
  projects: Array<{
    id: string;
    data: {
      title: string;
      description: string;
      status: string;
      category: string;
      order: number;
    };
  }>;
}

const { projects } = Astro.props;
---

<section class="py-32 px-8 bg-surface">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-16">
      <h2 class="font-black text-6xl md:text-8xl uppercase tracking-tighter italic">PROJECTS</h2>
      <a
        href="/projects"
        class="font-black text-sm uppercase tracking-widest text-secondary hover:text-white transition-none"
      >
        VIEW ALL <span class="material-symbols-outlined align-middle text-sm">arrow_forward</span>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project, i) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          status={project.data.status}
          category={project.data.category}
          slug={project.id}
          index={i + 1}
          total={projects.length}
        />
      ))}
    </div>
  </div>
</section>
