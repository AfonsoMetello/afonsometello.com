---
import Base from "../../layouts/Base.astro";
import BlogPostRow from "../../components/BlogPostRow.astro";
import { getCollection } from "astro:content";

const posts = (
  await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ["ALL POSTS", "AI & ARCHITECTURE", "LEADERSHIP", "OUTSYSTEMS"];
---

<Base title="Blog — Afonso Metello">
  <main>
    <section class="relative min-h-[614px] flex items-end px-6 md:px-12 pt-32 pb-20 bg-surface overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        <div class="w-full h-full bg-[radial-gradient(circle_at_center,_#2a2a2a,_transparent)]"></div>
      </div>
      <div class="relative z-10 w-full max-w-7xl mx-auto">
        <h1 class="text-[8rem] md:text-[16rem] font-black uppercase tracking-tighter leading-[0.8] mb-4 select-none">
          BLOG
        </h1>
        <p class="max-w-xl text-lg font-semibold uppercase text-secondary">
          THOUGHTS ON AI, ARCHITECTURE, AND BUILDING THINGS THAT MATTER.
        </p>
      </div>
    </section>

    <section class="bg-surface px-6 md:px-12 pb-32">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-wrap gap-6 py-12 mb-12 border-b border-outline-variant/30">
          {categories.map((cat, i) => (
            <button
              class:list={[
                "font-black uppercase text-xs tracking-widest",
                i === 0 ? "text-white border-b-2 border-white pb-1" : "text-neutral-500 hover:text-white transition-none",
              ]}
            >
              {cat}
            </button>
          ))}
        </div>

        <div class="flex flex-col">
          {posts.map((post) => (
            <BlogPostRow title={post.data.title} date={post.data.date} category={post.data.category} slug={post.id} />
          ))}
        </div>

        {posts.length === 0 && (
          <p class="text-secondary font-bold uppercase tracking-widest text-center py-20">COMING SOON</p>
        )}
      </div>
    </section>
  </main>
</Base>
