---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Projects — Afonso Metello">
  <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto">
    <header class="mb-20 md:mb-32">
      <h1 class="text-7xl md:text-[12rem] font-black uppercase tracking-tighter leading-[0.8] mb-8 mix-blend-difference">
        PROJECTS
      </h1>
      <div class="w-full h-1 bg-white mb-12"></div>
      <p class="max-w-2xl text-xl md:text-2xl font-bold uppercase leading-tight text-secondary">
        ARCHITECTING INTELLIGENCE THROUGH CODE AND CRAFT.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      {projects.map((project, i) => (
        <div class:list={[i >= 2 ? "md:mt-12" : ""]}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            status={project.data.status}
            category={project.data.category}
            slug={project.id}
            index={i + 1}
            total={projects.length}
          />
        </div>
      ))}
    </div>
  </main>
</Base>
