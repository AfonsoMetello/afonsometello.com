---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, status, category, year, stack, links, features } = project.data;
---

<Base title={`${title} — Afonso Metello`}>
  <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto">
    <header class="mb-12">
      <div class="flex flex-wrap items-baseline gap-4 md:gap-6">
        <h1 class="text-5xl md:text-8xl font-black uppercase tracking-tighter leading-none text-white">{title}</h1>
        <div class="flex gap-2 mb-2">
          <span class="px-3 py-1 bg-white text-black text-[10px] md:text-xs font-black uppercase tracking-widest">
            {status}
          </span>
          <span
            class="px-3 py-1 border border-outline-variant text-on-surface-variant text-[10px] md:text-xs font-black uppercase tracking-widest"
          >
            {category}
          </span>
        </div>
      </div>
    </header>

    <section class="mb-20 w-full">
      <div
        class="aspect-video w-full bg-surface-container-lowest border border-outline-variant/30 flex items-center justify-center"
      >
        <span class="text-outline-variant font-black uppercase tracking-widest text-sm">SCREENSHOT PLACEHOLDER</span>
      </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      <article class="lg:col-span-8 space-y-8">
        <div class="space-y-6 text-lg md:text-xl font-light leading-relaxed text-on-surface-variant">
          <Content />
        </div>

        {features && features.length > 0 && (
          <div class="pt-12">
            <h3 class="text-2xl font-black uppercase tracking-tight mb-8 text-white">Key Features</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {features.map((feature) => (
                <div class="p-6 bg-surface-container-low border-l-4 border-white">
                  <h4 class="font-black uppercase text-sm tracking-widest mb-2">{feature.title}</h4>
                  <p class="text-sm font-semibold opacity-70">{feature.description}</p>
                </div>
              ))}
            </div>
          </div>
        )}
      </article>

      <aside class="lg:col-span-4 space-y-12">
        <div class="space-y-10">
          <div class="space-y-6">
            <div>
              <span class="block text-[10px] font-black uppercase tracking-[0.3em] text-neutral-500 mb-2">STATUS</span>
              <p class="text-lg font-black uppercase text-white">{status}</p>
            </div>
            <div>
              <span class="block text-[10px] font-black uppercase tracking-[0.3em] text-neutral-500 mb-2">CATEGORY</span>
              <p class="text-lg font-black uppercase text-white">{category}</p>
            </div>
            <div>
              <span class="block text-[10px] font-black uppercase tracking-[0.3em] text-neutral-500 mb-2">YEAR</span>
              <p class="text-lg font-black uppercase text-white">{year}</p>
            </div>
          </div>

          {links && (
            <div class="flex flex-col gap-3">
              {links.demo && (
                <a
                  href={links.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between bg-white text-black px-6 py-4 font-black uppercase tracking-widest text-sm hover:bg-neutral-200 transition-none"
                >
                  <span>LIVE DEMO</span>
                  <span class="material-symbols-outlined">arrow_outward</span>
                </a>
              )}
              {links.forge && (
                <a
                  href={links.forge}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between border-2 border-outline-variant text-white px-6 py-4 font-black uppercase tracking-widest text-sm hover:bg-white hover:text-black transition-none"
                >
                  <span>FORGE LISTING</span>
                  <span class="material-symbols-outlined">launch</span>
                </a>
              )}
              {links.github && (
                <a
                  href={links.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between border-2 border-outline-variant text-white px-6 py-4 font-black uppercase tracking-widest text-sm hover:bg-white hover:text-black transition-none"
                >
                  <span>GITHUB SOURCE</span>
                  <span class="material-symbols-outlined">code</span>
                </a>
              )}
            </div>
          )}
        </div>

        <div class="pt-8">
          <span class="block text-[10px] font-black uppercase tracking-[0.3em] text-neutral-500 mb-4">STACK</span>
          <div class="flex flex-wrap gap-2">
            {stack.map((tech) => (
              <span class="px-3 py-1 bg-surface-container-high text-on-surface text-[10px] font-black uppercase tracking-widest">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </main>
</Base>
