---
import Base from "../layouts/Base.astro";
import HeroHome from "../components/HeroHome.astro";
import SectionProjects from "../components/SectionProjects.astro";
import SectionSpeaking from "../components/SectionSpeaking.astro";
import SectionBlog from "../components/SectionBlog.astro";
import SectionCommunity from "../components/SectionCommunity.astro";
import SectionConnect from "../components/SectionConnect.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);

const posts = (
  await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="Afonso Metello — Founder, AI-Augmented Architect, OutSystems Partner">
  <HeroHome />
  <SectionProjects projects={projects} />
  <SectionSpeaking />
  <SectionBlog posts={posts} />
  <SectionCommunity />
  <SectionConnect />
</Base>
